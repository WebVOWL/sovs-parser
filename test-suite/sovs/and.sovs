node a { text: "A"; kind: "owl:class"; }
node b { text: "B"; kind: "owl:class"; }
node c { text: "C"; kind: "owl:class"; }
node d { text: "D"; kind: "owl:class"; }
node intersection { kind: "anonymous"; }

edge intA from a to intersection { kind: "rdfs:subClassOf"; text: "Subclass Of"; }
edge intB from intersection to b { kind: "setRelation"; }
edge intC from intersection to c { kind: "setRelation"; }
edge intD from intersection to d { kind: "setRelation"; }
